{
  "expo": {
    "name": "ShapeCheck",
    "slug": "shapecheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#141416"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shapecheck.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#141416"
      },
      "package": "com.shapecheck.app"
    },
    "androidNavigationBar": {
      "backgroundColor": "#141416"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o ShapeCheck acesse sua câmera para tirar foto de perfil."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o ShapeCheck acesse suas fotos para escolher imagem de perfil."
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}